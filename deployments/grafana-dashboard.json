{
  "title": "a2a-mesh Overview",
  "timezone": "browser",
  "panels": [
    {
      "title": "Registered Agents",
      "type": "stat",
      "targets": [{ "expr": "a2a_registry_agents_total" }]
    },
    {
      "title": "Active Tasks",
      "type": "timeseries",
      "targets": [{ "expr": "a2a_tasks_active_total" }]
    },
    {
      "title": "Completed Tasks",
      "type": "timeseries",
      "targets": [{ "expr": "a2a_tasks_completed_total" }]
    },
    {
      "title": "Failed Tasks",
      "type": "timeseries",
      "targets": [{ "expr": "a2a_tasks_failed_total" }]
    },
    {
      "title": "RPC Latency p95",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(a2a_rpc_latency_bucket[5m])) by (le))" }
      ]
    },
    {
      "title": "Rate Limit Hits",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(a2a_rate_limit_hits_total[5m]))" }]
    },
    {
      "title": "Push Notification Success Ratio",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(a2a_push_notifications_success_total[5m])) / sum(rate(a2a_push_notifications_attempt_total[5m]))"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
